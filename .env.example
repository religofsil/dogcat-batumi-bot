# Telegram
BOT_TOKEN=123456:ABC
WEBHOOK_PATH_SECRET=change-me-random-string
# Optional: set X-Telegram-Bot-Api-Secret-Token on webhook
TELEGRAM_WEBHOOK_SECRET=

# Public URL of this service (no trailing slash), used for webhook and Mini App menu
PUBLIC_BASE_URL=https://bot.example.com
MINIAPP_PATH=/miniapp

# Database (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://curator:curator@postgres:5432/curator

# Session signing (min 32 random bytes as hex or any strong secret string)
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# Default timezone for scheduling (IANA)
DEFAULT_TZ=Asia/Tbilisi

# CORS: Mini App origin (usually https://web.telegram.org for in-app, plus your domain)
# Comma-separated
CORS_ORIGINS=https://web.telegram.org,https://yourdomain.com

# Call Telegram setWebhook on app startup (usually false; prefer explicit curl in production)
SET_WEBHOOK_ON_STARTUP=false

# HttpOnly session cookie: set false for local HTTP dev only
SECURE_COOKIES=true

# Python logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Diagnose miniapp (e.g. Telegram Desktop): grep stdout for [app.client.bootstrap] and [app.request]
# — bootstrap events are pre-auth; POST /api/auth/telegram lines show auth success/failure.

# Cat photo uploads (Docker Compose mounts a volume here by default)
UPLOAD_ROOT=/app/data/uploads
# Max multipart body per photo (10 MiB default; raise if reverse proxy allows it)
# MAX_UPLOAD_BYTES=10485760
# If nginx returns 413 on photo upload: raise client_max_body_size (e.g. client_max_body_size 12m;)

# Optional: NDJSON path for POST /api/__debug/client-log (local path on API host). For Docker, bind-mount a host dir and point this inside the container (e.g. /cursor-debug/debug.log).
# CLIENT_DEBUG_LOG_PATH=
