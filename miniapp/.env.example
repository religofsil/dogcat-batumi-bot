# Build-time (Vite). When true, client sends info-level events (e.g. boot_ready) to /api/client-log.
# VITE_CLIENT_LOG_VERBOSE=1
#
# Debugging Telegram Desktop load: server logs [app.client.bootstrap] for no_init_data / JS errors
# (no cookie). Correlates with [app.request] lines for POST /api/auth/telegram status.
